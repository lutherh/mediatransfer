# Immich — Environment Configuration
# Copy this file to .env.immich and fill in your values.

# ── Database (separate from MediaTransfer's Postgres) ──
DB_PASSWORD=immich
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# ── Immich ─────────────────────────────────────────────
# Where Immich stores the local media library and generated files
# (library, uploads, thumbnails, transcoded video, backups).
# This can grow very large. Prefer a dedicated large path outside the repo,
# for example `D:/immich-data` on Windows or `/mnt/media/immich-data` on Linux.
UPLOAD_LOCATION=./data/immich

# ── Scaleway S3 Storage ───────────────────────────────
# Reuse your existing Scaleway bucket. Immich stores originals here.
# The prefix "immich/" keeps these separate from your takeout uploads under "transfers/".
IMMICH_STORAGE_BACKEND=s3
IMMICH_S3_ENDPOINT=https://s3.fr-par.scw.cloud
IMMICH_S3_BUCKET=your-bucket-name
IMMICH_S3_ACCESS_KEY=your-scw-access-key
IMMICH_S3_SECRET_KEY=your-scw-secret-key
IMMICH_S3_REGION=fr-par
IMMICH_S3_PREFIX=immich
