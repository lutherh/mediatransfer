# Immich — Environment Configuration
# Copy this file to .env.immich and fill in your values.

# ── Database (separate from MediaTransfer's Postgres) ──
DB_PASSWORD=immich
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# ── Service Discovery ──
DB_URL=postgresql://immich:immich@database:5432/immich
REDIS_HOSTNAME=redis

# ── Immich ─────────────────────────────────────────────
# Immich has no native S3 backend. To use S3, mount your bucket on the host
# with rclone and point UPLOAD_LOCATION at that mount path.
# Start the mount:  ./scripts/mount-s3.sh
UPLOAD_LOCATION=./data/immich-s3

# Keep generated files local for performance/reliability.
THUMB_LOCATION=./data/immich/thumbs
ENCODED_VIDEO_LOCATION=./data/immich/encoded-video
PROFILE_LOCATION=./data/immich/profile
BACKUP_LOCATION=./data/immich/backups

# ── rclone S3 mount ──
# Used by scripts/mount-s3.sh
# S3 credentials (SCW_ACCESS_KEY, SCW_SECRET_KEY) are read from .env — not duplicated here.
RCLONE_BUCKET=your-bucket-name
RCLONE_PREFIX=immich

# ── Storage ──
# Immich uses local filesystem storage only (no S3 backend).
# With this setup, originals are written to your S3 mount at UPLOAD_LOCATION,
# while thumbs/transcodes/profile/backups stay local via the override vars above.
# Storage template is configured in the UI:
#   Administration → Settings → Storage Template
#   Recommended pattern: {{y}}/{{y}}-{{MM}}-{{dd}}/{{filename}}

# ── Cloudflare Tunnel ──
# Token from Cloudflare Zero Trust → Networks → Tunnels → <home-immich> → Install connector.
# Paste the full `eyJhIjoi...` string (everything after `cloudflared.exe service install `).
# DO NOT commit; .env.immich is gitignored.
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── LAN endpoint (mobile uploads bypass the tunnel on home Wi‑Fi) ──
# Leave blank to let scripts/start-all.sh auto‑detect the host's LAN IP.
# Falls back to 127.0.0.1 if unset, so 2283 is never accidentally exposed.
IMMICH_LAN_IP=