{
  "name": "mediatransfer",
  "version": "0.1.0",
  "description": "Local tool that transfers assets from one cloud to another. Runs entirely on your machine.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "app:setup": "node scripts/local-dev.mjs --setup-only",
    "app:dev": "node scripts/local-dev.mjs",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:verbose": "vitest run --coverage --reporter=verbose",
    "lint": "tsc --noEmit",
    "transfer:picker:scaleway": "tsx scripts/picker-to-scaleway-transfer.ts",
    "transfer:google-batch:scaleway": "tsx scripts/google-photos-batch-transfer.ts",
    "takeout:scan": "tsx scripts/takeout-scan.ts",
    "takeout:upload": "tsx scripts/takeout-upload.ts",
    "takeout:resume": "tsx scripts/takeout-resume.ts",
    "takeout:verify": "tsx scripts/takeout-verify.ts",
    "takeout:process": "tsx scripts/takeout-process.ts",
    "takeout:watch": "tsx scripts/takeout-watch.ts",
    "takeout:cleanup": "tsx scripts/takeout-cleanup.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lutherh/mediatransfer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0"
  },
  "bugs": {
    "url": "https://github.com/lutherh/mediatransfer/issues"
  },
  "homepage": "https://github.com/lutherh/mediatransfer#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "music-metadata": "^11.12.3",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/lib-storage": "^3.1014.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "exifr": "^7.1.3",
    "extract-zip": "^2.0.1",
    "fastify": "^5.8.2",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "tar": "^7.5.12",
    "zod": "^4.3.6"
  }
}
