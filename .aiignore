# AI assistant ignore file (Copilot, Claude, Cursor, Codex, Gemini, etc.)
#
# Mirrors .gitignore but is tuned for *context windows*: excludes large,
# generated, binary, secret, or otherwise-irrelevant artifacts so that
# AI tools don't waste tokens (or accidentally read secrets).
#
# Tools that consume this file (via copies/symlinks below):
#   .copilotignore   — GitHub Copilot (community convention)
#   .claudeignore    — Claude Code
#   .cursorignore    — Cursor
#   .aiexclude       — Gemini Code Assist / JetBrains AI

# ── Dependencies & build output ──
node_modules/
**/node_modules/
dist/
build/
out/
.next/
.turbo/
.vite/
.cache/
.parcel-cache/
.svelte-kit/

# ── Test / coverage artifacts ──
coverage/
**/coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# ── Lockfiles (huge, rarely useful for reasoning) ──
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
*.lock

# ── Generated source ──
src/generated/
**/generated/
*.d.ts.map
*.js.map
*.css.map

# ── Prisma generated client ──
prisma/generated/
src/generated/prisma/

# ── Logs ──
*.log
logs/
data/logs/
debug-output.txt
log_dump.txt
test-output.txt
repair-output.txt
scripts/temp-logs-from-immich-server.txt
scripts/immich-update-log.txt

# ── Secrets & env (NEVER feed to AI) ──
.env
.env.*
!.env.example
!.env.immich.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ── VCS & IDE metadata ──
.git/
.svn/
.hg/
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.history/

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Databases ──
*.db
*.sqlite
*.sqlite3
*.mdb

# ── Archives & binaries ──
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.iso
*.dmg
*.exe
*.dll
*.so
*.dylib
*.class
*.jar
*.war

# ── Media (huge, opaque to LLMs) ──
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp
*.heic
*.heif
*.svg
*.ico
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.mp3
*.wav
*.flac
*.ogg
*.pdf
*.psd

# ── Docker / runtime data volumes ──
data/
!data/.gitkeep

# Project-specific runtime data (already gitignored, restate for clarity)
data/takeout/
data/thumbs/
data/immich/
data/immich-s3/
data/immich-s3-mount/
data/immich-thumbs/
data/immich-encoded-video/
data/immich-profile/
data/immich-backups/
data/s3-mount/
data/rclone-rc.sock

# ── State / backup snapshots (contain real S3 keys & album names) ──
*.bak
*.bak2
state.json.pre-*
state.backup-*

# ── Misc large/irrelevant text dumps ──
*.csv
*.tsv
*.ndjson
google_photos_inspiration.html
archive_browser.html
migration-done-years.txt

# ── One-off / root-level test & debug scripts (per .gitignore) ──
test-ffmpeg-resolve.ts
test-s3-*.ts
test-sidecar-fix.ts
check-s3-size.ts
delete-safe-downloads.ts
scripts/debug-*.ts
scripts/test-*.ts
scripts/_test-*
scripts/*.bak
scripts/*.bak2

# ── Frontend build cache ──
frontend/dist/
frontend/coverage/
frontend/.vite/
