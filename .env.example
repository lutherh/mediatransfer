# MediaTransfer — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is .gitignore'd.

# ── Node ──────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
HOST=127.0.0.1
PORT=3000
API_AUTH_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Frontend ──────────────────────────────────
# Base URL the browser uses to reach the API. Injected as a Vite build arg by
# docker-compose.yml. Leave empty to fall back to http://<hostname>:3000.
# VITE_API_BASE_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=mediatransfer
POSTGRES_PASSWORD=mediatransfer
POSTGRES_DB=mediatransfer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mediatransfer:mediatransfer@localhost:5432/mediatransfer

# ── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Encryption ────────────────────────────────
# Used to encrypt stored cloud credentials (AES-256-GCM)
ENCRYPTION_SECRET=change-me-to-a-random-secret

# ── Scaleway Object Storage ────────────────────
# S3-compatible storage. Get keys from https://console.scaleway.com/iam/api-keys
# Note: SCW_ACCESS_KEY, SCW_SECRET_KEY and SCW_REGION are also read by the
# rclone-s3 mount service in docker-compose.immich.yml — keep them in sync.
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_REGION=fr-par
SCW_BUCKET=
SCW_PREFIX=
# S3 storage class for new uploads (e.g. STANDARD, ONEZONE_IA, GLACIER).
# ONEZONE_IA is cheaper for infrequently-accessed backup data.
SCW_STORAGE_CLASS=ONEZONE_IA
# Explicit endpoint URL override — required for non-Scaleway providers.
# Examples: https://s3.amazonaws.com (AWS), https://s3.us-west-001.backblazeb2.com (B2)
# Leave empty to auto-derive from SCW_REGION (Scaleway default).
SCW_ENDPOINT_URL=
# Set to "false" to use virtual-hosted-style requests (required for AWS S3).
# Defaults to "true" (path-style — correct for Scaleway, Backblaze B2, Cloudflare R2).
SCW_FORCE_PATH_STYLE=true
# Increase if you see "S3 list page failed ... AbortError" on large buckets / slower links.
SCW_S3_REQUEST_TIMEOUT_MS=300000
SCW_S3_LIST_MAX_RETRIES=5

# ── Thumbnail cache ────────────────────────────
THUMB_CACHE_DIR=./data/thumbs

# ── Google Photos ─────────────────────────────
# OAuth2 credentials from Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_TOKEN_EXPIRY_DATE=
GOOGLE_BATCH_STATE_PATH=./data/takeout/google-api-state.json
GOOGLE_BATCH_TEMP_DIR=./data/takeout/work/google-api-batches

# ── Google Takeout migration ───────────────────
# Primary full-library migration path:
# Google Takeout export -> local unpack -> resumable upload
TAKEOUT_INPUT_DIR=./data/takeout/input
TAKEOUT_WORK_DIR=./data/takeout/work
TAKEOUT_ARCHIVE_DIR=
TRANSFER_STATE_PATH=./data/takeout/state.json
UPLOAD_CONCURRENCY=4
UPLOAD_RETRY_COUNT=5
# Number of concurrent BullMQ workers for background jobs (1–64, default 2).
WORKER_CONCURRENCY=2

# ── Immich ─────────────────────────────────────
# Local Immich instance API key (used by migration/verification scripts)
IMMICH_API_KEY=
IMMICH_URL=http://localhost:2283

For debugging Immich, set the log level to "verbose" (default is "info"). This will produce more detailed logs, which can help identify issues. Remember to revert this back to "info" or a less verbose level in production to avoid excessive logging.
#IMMICH_LOG_LEVEL=verbose